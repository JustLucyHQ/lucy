{
  "name": "lucy-ai",
  "version": "0.1.6",
  "private": true,
  "main": "electron/main.js",
  "bin": {
    "lucy": "./cli/bin.mjs"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:standalone": "cross-env NEXT_PUBLIC_SUPABASE_URL= NEXT_PUBLIC_SUPABASE_ANON_KEY= SUPABASE_INTERNAL_URL= SUPABASE_SERVICE_ROLE_KEY= NEXT_PUBLIC_GA_ID= next dev -p 3060",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "desktop:build": "node scripts/desktop-build.js",
    "desktop:prepare": "npm run desktop:build && node electron/copy-standalone.js",
    "electron:dev": "npm run desktop:prepare && electron .",
    "dist": "npm run desktop:prepare && electron-builder",
    "icons": "node electron/gen-icons.js",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "lucy": "tsx cli/index.ts",
    "mcp": "npx tsx lib/mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/generative-ai": "^0.24.1",
    "@lobehub/icons": "^5.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@xyflow/react": "^12.11.0",
    "cron-parser": "^4.9.0",
    "grammy": "^1.44.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "simple-icons": "^16.24.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.10",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "postcss": "$postcss"
  }
}
