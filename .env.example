# AI Provider API Keys
# Copy this file to .env.local and fill in your keys

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Admin role (no env var needed)
# Admin is a per-user role stored in Supabase auth app_metadata (lucy_role)
# and managed from the Admin panel (/admin → Users & roles). On a fresh
# deployment the oldest account is auto-promoted to admin.
# LUCY_ADMIN_EMAIL is OPTIONAL legacy bootstrap only: if set, it picks which
# account gets auto-promoted first. It is not checked afterwards.
#LUCY_ADMIN_EMAIL=

# Canonical public URL of this deployment (production: https://justlucy.ai).
# Drives absolute OG/canonical/manifest URLs. NOTE: NEXT_PUBLIC_* vars are
# inlined at BUILD time — set this before `next build`, not just at runtime.
NEXT_PUBLIC_SITE_URL=https://justlucy.ai

# Google Analytics (gtag.js) measurement ID. When set, the GA tag loads only on
# public marketing pages (landing, download, docs) — never the internal app.
# Public value (appears in page source). The production ID lives in the
# committed .env.production; the desktop build clears it (no telemetry).
NEXT_PUBLIC_GA_ID=

# Supabase (optional — leave empty for standalone/localStorage mode)
# When set, Lucy will use Supabase PostgreSQL for persistence and Supabase Auth for login.
# Run the migration in lib/supabase/schema.sql against your Supabase project first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only, NEVER exposed to the browser. Required for
# memory, connectors, screening, and admin operations in connected mode.
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (required for password reset + email-OTP 2FA in connected mode).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Local LLM (optional — auto-detected)
# Ollama: https://ollama.com  — run `ollama serve` to start
# LM Studio: https://lmstudio.ai — enable the local server in the app
# Leave these empty to use the defaults below.
OLLAMA_URL=http://localhost:11434
LM_STUDIO_URL=http://localhost:1234
